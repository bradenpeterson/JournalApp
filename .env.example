# Clerk Environment Variables
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Supabase Environment Variables
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Environment Variables (Phase 3 mood analysis — `getOpenAIClient()` returns null until set)
OPENAI_API_KEY=

# Redis (Phase 4 — BullMQ workers; from Railway Redis or local `redis://…`)
REDIS_URL=

# Public site URL for links in worker emails (e.g. capsule unlock); optional in dev
NEXT_PUBLIC_APP_URL=

# Resend — `Journal <onboarding@resend.dev>` works in dev without verifying a domain (see Resend dashboard)
RESEND_API_KEY=
# Optional default From for all transactional email
RESEND_DEFAULT_FROM=
WEEKLY_DIGEST_FROM=
CAPSULE_UNLOCK_FROM=

